% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'ike' && ref $event->{raw}{ike} eq 'HASH') {
  % my $i = $event->{raw}{ike};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">IKE Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(init_spi resp_spi message_id maj_ver min_ver exchange_type role doi encrypted_payloads)) {
          % next unless defined $i->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $i->{$field} %></td>
        </tr>
        % }
        % for my $field (qw(errors notify vendor_ids payload)) {
          % next unless defined $i->{$field} && ref $i->{$field} eq 'ARRAY' && @{$i->{$field}};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= join(', ', @{$i->{$field}}) %></td>
        </tr>
        % }
        % if (ref $i->{ikev1} eq 'HASH') {
          % my $v1 = $i->{ikev1};
          % for my $field (qw(sa_life_type sa_life_duration enc_alg hash_alg auth_method dh_group)) {
            % next unless defined $v1->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev1.<%= $field %></th>
          <td class="font-monospace"><%= $v1->{$field} %></td>
        </tr>
          % }
          % if (ref $v1->{transforms} eq 'ARRAY' && @{$v1->{transforms}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev1.transforms</th>
          <td class="font-monospace">
            % for my $t (@{$v1->{transforms}}) {
              <%= ref $t eq 'HASH' ? join(' ', map { "$_=$t->{$_}" } sort keys %$t) : $t %><br>
            % }
          </td>
        </tr>
          % }
        % }
        % if (ref $i->{ikev2} eq 'HASH') {
          % my $v2 = $i->{ikev2};
          % for my $field (qw(alg_enc alg_auth alg_prf alg_dh alg_esn)) {
            % next unless defined $v2->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev2.<%= $field %></th>
          <td class="font-monospace"><%= $v2->{$field} %></td>
        </tr>
          % }
          % for my $field (qw(notify child_sa)) {
            % next unless defined $v2->{$field} && ref $v2->{$field} eq 'ARRAY' && @{$v2->{$field}};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev2.<%= $field %></th>
          <td class="font-monospace"><%= join(', ', @{$v2->{$field}}) %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if ($pretty_raw) {
<div class="card border-secondary">
  <div class="card-header py-2 d-flex align-items-center gap-2">
    <button class="btn btn-sm btn-outline-secondary" type="button"
            data-bs-toggle="collapse" data-bs-target="#raw-json-panel">
      Raw JSON
    </button>
    <button class="btn btn-sm btn-outline-secondary" type="button" id="download-json-btn">
      Download JSON
    </button>
    % if (ref $event->{raw} eq 'HASH' && defined $event->{raw}{payload}) {
    <button class="btn btn-sm btn-outline-secondary" type="button" id="download-payload-btn"
            data-payload="<%= $event->{raw}{payload} %>"
            data-filename="payload-<%= $table %>-<%= $id %>.bin">
      Download Payload
    </button>
    % }
    <span class="text-muted small">click to expand</span>
  </div>
  <div class="collapse" id="raw-json-panel">
    <div class="card-body p-2">
      <pre class="raw-json mb-0"><%= $pretty_raw %></pre>
    </div>
  </div>
</div>
% }

% if ($self->escalation_enable) {
<!-- Escalation history for this event -->
<div class="card border-secondary mt-3" id="escalation-history">
  <div class="card-header py-1 small text-muted d-flex justify-content-between align-items-center">
    <span>Escalations</span>
    <span id="esc-history-status" class="text-muted"></span>
  </div>
  <div class="p-2" id="esc-history-body">
    <span class="text-muted small">Loading…</span>
  </div>
</div>

<!-- Escalate modal -->
<div class="modal fade" id="escalate-modal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content bg-dark text-light border-secondary">
      <div class="modal-header py-2 border-secondary">
        <h6 class="modal-title">Escalate Event #<%= $id %> (<%= $cap_table %>)</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-2">
          <label class="form-label small text-muted mb-1">Targets</label>
          <div id="esc-targets" class="border border-secondary rounded p-2">
            <span class="text-muted small">Loading…</span>
          </div>
        </div>
        <div class="mb-2">
          <label class="form-label small text-muted mb-1">Note</label>
          <textarea id="esc-note" class="form-control form-control-sm" rows="2"></textarea>
        </div>
        <div class="mb-2">
          <label class="form-label small text-muted mb-1">Requested by</label>
          <input type="text" id="esc-requested-by" class="form-control form-control-sm">
        </div>
        <div id="esc-error" class="text-warning small" style="display:none"></div>
        <div id="esc-results" class="small mt-2" style="display:none"></div>
      </div>
      <div class="modal-footer py-2 border-secondary">
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-sm btn-danger" id="esc-send-btn">Escalate</button>
      </div>
    </div>
  </div>
</div>
% }

% }

<!-- Domain Info Modal -->
<div class="modal fade" id="domaininfo-modal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content bg-dark text-light border-secondary">
      <div class="modal-header py-2 border-secondary">
        <h6 class="modal-title" id="domaininfo-modal-title">Domain Info</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="domaininfo-loading" class="text-center text-muted py-3">Loading…</div>
        <div id="domaininfo-content" style="display:none">
          <div class="mb-2">
            <span class="text-muted small fw-semibold">DNS Records</span>
            <div id="domaininfo-dns" class="font-monospace small mt-1"></div>
            <div id="domaininfo-dns-error" class="text-warning small mt-1" style="display:none"></div>
          </div>
          <div class="mb-2">
            <span class="text-muted small fw-semibold" id="domaininfo-whois-label">WHOIS</span>
            <pre id="domaininfo-whois" class="small mt-1 mb-0" style="white-space:pre-wrap;max-height:400px;overflow-y:auto"></pre>
          </div>
          <div id="domaininfo-dnstracer-section" style="display:none">
            <span class="text-muted small fw-semibold">dnstracer</span>
            <div id="domaininfo-dnstracer-error" class="text-warning small mt-1" style="display:none"></div>
            <pre id="domaininfo-dnstracer" class="small mt-1 mb-0" style="white-space:pre-wrap;max-height:400px;overflow-y:auto"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.http-body-dl').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var base64Body = this.dataset.body;
      var filename = this.dataset.filename;
      var type     = this.dataset.type.split(';')[0].trim() || 'application/octet-stream';
      var binary   = atob(base64Body);
      var bytes    = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) { bytes[i] = binary.charCodeAt(i); }
      var blob = new Blob([bytes], { type: type });
      var url  = URL.createObjectURL(blob);
      var downloadLink = document.createElement('a');
      downloadLink.href     = url;
      downloadLink.download = filename;
      downloadLink.click();
      URL.revokeObjectURL(url);
    });
  });

  var domainModal = new bootstrap.Modal(document.getElementById('domaininfo-modal'));
  document.querySelectorAll('.domain-info-btn').forEach(function(el) {
    el.addEventListener('click', function() {
      var domain = this.dataset.domain;
      document.getElementById('domaininfo-modal-title').textContent = domain;
      document.getElementById('domaininfo-loading').style.display = '';
      document.getElementById('domaininfo-content').style.display = 'none';
      domainModal.show();
      fetch('/api/domaininfo/' + encodeURIComponent(domain))
        .then(function(response) { return response.json(); })
        .then(function(data) {
          var dnsEl = document.getElementById('domaininfo-dns');
          if (data.dns && Object.keys(data.dns).length) {
            var order = ['A','AAAA','CNAME','MX','NS','TXT','SOA','CAA','SRV','PTR'];
            var keys  = Object.keys(data.dns).sort(function(a,b) {
              var ai = order.indexOf(a), bi = order.indexOf(b);
              if (ai === -1) ai = 999;
              if (bi === -1) bi = 999;
              return ai - bi;
            });
            dnsEl.innerHTML = keys.map(function(type) {
              return data.dns[type].map(function(value) {
                return '<strong>' + type + '</strong> ' + value;
              }).join('<br>');
            }).join('<br>');
          } else {
            dnsEl.textContent = '(none)';
          }
          var errEl = document.getElementById('domaininfo-dns-error');
          if (data.dns_error) { errEl.textContent = data.dns_error; errEl.style.display = ''; }
          else { errEl.style.display = 'none'; }
          document.getElementById('domaininfo-whois-label').textContent =
            (data.whois_domain && data.whois_domain !== domain)
              ? 'WHOIS (' + data.whois_domain + ')' : 'WHOIS';
          document.getElementById('domaininfo-whois').textContent = data.whois || '(none)';
          var dtSection = document.getElementById('domaininfo-dnstracer-section');
          var dtErrEl   = document.getElementById('domaininfo-dnstracer-error');
          if (data.dnstracer || data.dnstracer_error) {
            dtSection.style.display = '';
            document.getElementById('domaininfo-dnstracer').textContent = data.dnstracer || '';
            if (data.dnstracer_error) { dtErrEl.textContent = data.dnstracer_error; dtErrEl.style.display = ''; }
            else { dtErrEl.style.display = 'none'; }
          } else {
            dtSection.style.display = 'none';
          }
          document.getElementById('domaininfo-loading').style.display = 'none';
          document.getElementById('domaininfo-content').style.display = '';
        })
        .catch(function() {
          document.getElementById('domaininfo-dns').textContent = 'Error fetching data';
          document.getElementById('domaininfo-whois').textContent = '';
          document.getElementById('domaininfo-loading').style.display = 'none';
          document.getElementById('domaininfo-content').style.display = '';
        });
    });
  });

  var payloadBtn = document.getElementById('download-payload-btn');
  if (payloadBtn) {
    payloadBtn.addEventListener('click', function() {
      var binary  = atob(this.dataset.payload);
      var bytes   = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) { bytes[i] = binary.charCodeAt(i); }
      var blob = new Blob([bytes], { type: 'application/octet-stream' });
      var url  = URL.createObjectURL(blob);
      var downloadLink = document.createElement('a');
      downloadLink.href     = url;
      downloadLink.download = this.dataset.filename;
      downloadLink.click();
      URL.revokeObjectURL(url);
    });
  }

  var dlBtn = document.getElementById('download-json-btn');
  if (dlBtn) {
    dlBtn.addEventListener('click', function() {
      var json = document.querySelector('#raw-json-panel pre').textContent;
      var blob = new Blob([json], { type: 'application/json' });
      var url  = URL.createObjectURL(blob);
      var downloadLink = document.createElement('a');
      downloadLink.href     = url;
      downloadLink.download = 'event-<%= $table %>-<%= $id %>.json';
      downloadLink.click();
      URL.revokeObjectURL(url);
    });
  }

  // The IP info modal + lookup lives in the layout; just wire the buttons.
  document.querySelectorAll('.ip-info-btn').forEach(function(el) {
    el.addEventListener('click', function() {
      window.showIpInfo(this.dataset.ip);
    });
  });

  // PCAP download controls
  (function() {
    var box = document.getElementById('pcap-controls');
    if (!box) { return; }
    var remoteEl = document.getElementById('pcap-remote');
    var setEl    = document.getElementById('pcap-set');

    // Set list comes from the shared loader in the layout.
    window.loadViraniSets(setEl, remoteEl.value);
    if (remoteEl.tagName === 'SELECT') {
      remoteEl.addEventListener('change', function() { window.loadViraniSets(setEl, this.value); });
    }

    // Download: fetch from the remote (streamed by the server).
    document.getElementById('pcap-dl').addEventListener('click', function() {
      var url = '/event/' + encodeURIComponent(box.dataset.table) + '/' + encodeURIComponent(box.dataset.id)
              + '/pcap?remote=' + encodeURIComponent(remoteEl.value)
              + '&set=' + encodeURIComponent(setEl.value);
      window.location.href = url;
    });

    // Local command: show the virani invocation to run on the box with the PCAPs.
    var reveal = document.getElementById('pcap-local-cmd');
    var cmdEl  = document.getElementById('pcap-cmd');
    document.getElementById('pcap-local').addEventListener('click', function(event) {
      event.preventDefault();
      var set = setEl.value;
      var cmd = 'virani -s ' + box.dataset.start + ' -e ' + box.dataset.end
              + (set ? ' --set ' + set : '')
              + ' -w event-' + box.dataset.id + '.pcap'
              + " -f '" + box.dataset.filter + "'";
      cmdEl.textContent = cmd;
      bootstrap.Collapse.getOrCreateInstance(reveal).show();
    });
    document.getElementById('pcap-copy').addEventListener('click', function() {
      if (navigator.clipboard) { navigator.clipboard.writeText(cmdEl.textContent); }
    });
    document.getElementById('pcap-cmd-close').addEventListener('click', function() {
      bootstrap.Collapse.getOrCreateInstance(reveal).hide();
    });
  })();
});
</script>

% if ($self->escalation_enable && $event) {
<script>
document.addEventListener('DOMContentLoaded', function() {
  var escTable = '<%= $table %>';
  var escId    = '<%= $id %>';

  function statusBadge(status) {
    var badgeClass = { sent: 'bg-success', failed: 'bg-danger', pending: 'bg-secondary' }[status] || 'bg-secondary';
    var badgeEl = document.createElement('span');
    badgeEl.className = 'badge ' + badgeClass;
    badgeEl.textContent = status;
    return badgeEl;
  }

  // Escalation history — one row per recorded escalation, with the raw
  // payload behind an expando.
  function loadHistory() {
    var body     = document.getElementById('esc-history-body');
    var statusEl = document.getElementById('esc-history-status');
    fetch('/api/escalation/history/' + encodeURIComponent(escTable) + '/' + encodeURIComponent(escId))
      .then(function(response) { return response.json(); })
      .then(function(data) {
        var rows = data.escalations || [];
        statusEl.textContent = rows.length + ' escalation' + (rows.length === 1 ? '' : 's');
        body.innerHTML = '';
        if (data.error) {
          var err = document.createElement('span');
          err.className = 'text-warning small';
          err.textContent = data.error;
          body.appendChild(err);
          return;
        }
        if (!rows.length) {
          var none = document.createElement('span');
          none.className = 'text-muted small';
          none.textContent = 'This event has not been escalated.';
          body.appendChild(none);
          return;
        }
        var table = document.createElement('table');
        table.className = 'table table-dark table-sm table-bordered mb-0';
        var thead = document.createElement('thead');
        thead.className = 'table-secondary';
        thead.innerHTML = '<tr><th>Time</th><th>Target</th><th>Status</th><th>Requested By</th>'
          + '<th>Note</th><th>Error</th><th>Raw</th></tr>';
        table.appendChild(thead);
        var tbody = document.createElement('tbody');
        rows.forEach(function(row) {
          var rowEl = document.createElement('tr');
          function cell(text) {
            var cellEl = document.createElement('td');
            cellEl.textContent = (text == null ? '' : text);
            return cellEl;
          }
          rowEl.appendChild(cell(row.timestamp));
          // target_name is snapshotted at attempt time; a null target_id
          // alongside a name means the target has since been deleted
          var targetLabel = row.target_name || '(unknown target)';
          if (row.target_name && !row.target_id) { targetLabel += ' (deleted)'; }
          rowEl.appendChild(cell(targetLabel));
          var statusCell = document.createElement('td');
          statusCell.appendChild(statusBadge(row.status));
          rowEl.appendChild(statusCell);
          rowEl.appendChild(cell(row.requested_by));
          rowEl.appendChild(cell(row.note));
          var errorCell = cell(row.error);
          errorCell.className = row.error ? 'text-warning small' : '';
          rowEl.appendChild(errorCell);
          var rawCell = document.createElement('td');
          if (row.raw) {
            var details = document.createElement('details');
            var summary = document.createElement('summary');
            summary.className = 'text-muted small';
            summary.textContent = 'raw';
            var pre = document.createElement('pre');
            pre.className = 'small mb-0';
            pre.style.whiteSpace = 'pre-wrap';
            pre.style.maxHeight = '300px';
            pre.style.overflowY = 'auto';
            pre.textContent = JSON.stringify(row.raw, null, 2);
            details.appendChild(summary);
            details.appendChild(pre);
            rawCell.appendChild(details);
          }
          rowEl.appendChild(rawCell);
          tbody.appendChild(rowEl);
        });
        table.appendChild(tbody);
        var wrap = document.createElement('div');
        wrap.className = 'table-responsive';
        wrap.appendChild(table);
        body.appendChild(wrap);
      })
      .catch(function(err) {
        body.innerHTML = '';
        var errSpan = document.createElement('span');
        errSpan.className = 'text-warning small';
        errSpan.textContent = 'Failed to load escalations: ' + err;
        body.appendChild(errSpan);
      });
  }
  loadHistory();

  // Escalate modal — target list is fetched when the modal opens so it is
  // always current.
  var modalEl = document.getElementById('escalate-modal');
  modalEl.addEventListener('show.bs.modal', function() {
    var box = document.getElementById('esc-targets');
    document.getElementById('esc-error').style.display   = 'none';
    document.getElementById('esc-results').style.display = 'none';
    box.innerHTML = '<span class="text-muted small">Loading…</span>';
    fetch('/api/escalation/targets')
      .then(function(response) { return response.json(); })
      .then(function(data) {
        var targets = (data.targets || []).filter(function(target) { return target.enabled; });
        box.innerHTML = '';
        if (!targets.length) {
          box.innerHTML = '<span class="text-muted small">No enabled escalation targets configured.'
            + ' Add one on the <a href="/escalation" class="text-danger">Escalation</a> page.</span>';
          return;
        }
        targets.forEach(function(target) {
          var wrap = document.createElement('div');
          wrap.className = 'form-check';
          var input = document.createElement('input');
          input.className = 'form-check-input esc-target-check';
          input.type = 'checkbox';
          input.value = target.id;
          input.id = 'esc-target-' + target.id;
          var label = document.createElement('label');
          label.className = 'form-check-label small';
          label.htmlFor = input.id;
          label.textContent = target.name + ' (' + target.type + ')' + (target.description ? ' — ' + target.description : '');
          wrap.appendChild(input);
          wrap.appendChild(label);
          box.appendChild(wrap);
        });
      })
      .catch(function(err) {
        box.innerHTML = '<span class="text-warning small">Failed to load targets: ' + err + '</span>';
      });
  });

  document.getElementById('esc-send-btn').addEventListener('click', function() {
    var errEl     = document.getElementById('esc-error');
    var resultsEl = document.getElementById('esc-results');
    errEl.style.display = 'none';
    var ids = [];
    document.querySelectorAll('.esc-target-check:checked').forEach(function(checkbox) { ids.push(checkbox.value); });
    if (!ids.length) {
      errEl.textContent = 'Select at least one target.';
      errEl.style.display = '';
      return;
    }
    var btn = this;
    btn.disabled = true;
    fetch('/api/escalation/escalate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        table:        escTable,
        id:           escId,
        target_ids:   ids,
        note:         document.getElementById('esc-note').value,
        requested_by: document.getElementById('esc-requested-by').value
      })
    })
      .then(function(response) { return response.json().then(function(data) { return { ok: response.ok, data: data }; }); })
      .then(function(res) {
        btn.disabled = false;
        if (!res.ok || res.data.error) {
          errEl.textContent = res.data.error || 'escalation failed';
          errEl.style.display = '';
          return;
        }
        resultsEl.innerHTML = '';
        (res.data.results || []).forEach(function(result) {
          var line = document.createElement('div');
          line.appendChild(statusBadge(result.status));
          var text = document.createElement('span');
          text.className = 'ms-1';
          text.textContent = ' ' + (result.target_name || ('target #' + result.target_id))
            + (result.error ? ' — ' + result.error : '');
          line.appendChild(text);
          resultsEl.appendChild(line);
        });
        resultsEl.style.display = '';
        loadHistory();
      })
      .catch(function(err) {
        btn.disabled = false;
        errEl.textContent = 'escalation failed: ' + err;
        errEl.style.display = '';
      });
  });
});
</script>
% }
