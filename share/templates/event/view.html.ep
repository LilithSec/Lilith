        % if (ref $s->{kerberos} eq 'HASH') {
          % for my $field (qw(realm)) {
            % next unless defined $s->{kerberos}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">kerberos.<%= $field %></th>
          <td class="font-monospace"><%= $s->{kerberos}{$field} %></td>
        </tr>
          % }
