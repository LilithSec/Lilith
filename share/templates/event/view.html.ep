        % if (ref $s->{errors} eq 'ARRAY' && @{$s->{errors}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">errors</th>
          <td class="font-monospace"><%= join(', ', @{$s->{errors}}) %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

