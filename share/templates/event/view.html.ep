        % for my $field (qw(message_id type operation)) {
          % next unless defined $l->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $l->{$field} %></td>
        </tr>
        % }
        % if (ref $l->{request} eq 'HASH') {
          % my $req = $l->{request};
          % for my $field (qw(operation)) {
            % next unless defined $req->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">request.<%= $field %></th>
          <td class="font-monospace"><%= $req->{$field} %></td>
        </tr>
          % }
          % if (ref $req->{bind} eq 'HASH') {
            % for my $field (qw(dn version)) {
              % next unless defined $req->{bind}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">request.bind.<%= $field %></th>
          <td class="font-monospace"><%= $req->{bind}{$field} %></td>
        </tr>
            % }
          % }
          % if (ref $req->{search} eq 'HASH') {
            % for my $field (qw(base_dn filter scope)) {
              % next unless defined $req->{search}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">request.search.<%= $field %></th>
          <td class="font-monospace"><%= $req->{search}{$field} %></td>
        </tr>
            % }
            % if (ref $req->{search}{attributes} eq 'ARRAY' && @{$req->{search}{attributes}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">request.search.attributes</th>
          <td class="font-monospace"><%= join(', ', @{$req->{search}{attributes}}) %></td>
        </tr>
            % }
          % }
        % }
        % if (ref $l->{response} eq 'HASH') {
          % for my $field (qw(result_code dn message)) {
            % next unless defined $l->{response}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">response.<%= $field %></th>
          <td class="font-monospace"><%= $l->{response}{$field} %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'mdns' && ref $event->{raw}{mdns} eq 'HASH') {
  % my $m = $event->{raw}{mdns};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">MDNS Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(type id flags)) {
          % next unless defined $m->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $m->{$field} %></td>
        </tr>
        % }
        % if (ref $m->{queries} eq 'ARRAY' && @{$m->{queries}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">queries</th>
          <td class="font-monospace">
            % for my $q (@{$m->{queries}}) {
              <%= ref $q eq 'HASH' ? join(' ', map { "$_=$q->{$_}" } sort keys %$q) : $q %><br>
            % }
          </td>
        </tr>
        % }
        % if (ref $m->{answers} eq 'ARRAY' && @{$m->{answers}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">answers</th>
          <td class="font-monospace">
            % for my $a (@{$m->{answers}}) {
              <%= ref $a eq 'HASH' ? join(' ', map { "$_=$a->{$_}" } sort keys %$a) : $a %><br>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

