% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'ldap' && ref $event->{raw}{ldap} eq 'HASH') {
  % my $l = $event->{raw}{ldap};
<div class="card border-secondary mb-3">
