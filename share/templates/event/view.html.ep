% my $cap_table = ucfirst($table);
% layout 'default';
% title "Event #$id ($cap_table)";

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <a href="/search?table=<%= $table %>&search=1" class="text-danger">Search (<%= $cap_table %>)</a>
    </li>
    <li class="breadcrumb-item active">Event #<%= $id %></li>
  </ol>
</nav>

% if ($error) {
<div class="alert alert-danger py-2">
  <strong>Error:</strong> <%= $error %>
</div>
% }

% if (!$event) {
<div class="alert alert-warning py-2">Event #<%= $id %> not found in the <em><%= $table %></em> table.</div>
% } else {

<div class="card border-secondary mb-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span>
      Event <span class="text-danger fw-bold">#<%= $id %></span>
      <span class="badge bg-secondary ms-2"><%= $cap_table %></span>
    </span>
    <div class="d-flex align-items-center gap-2">
      % if ($pcap_available) {
      <div id="pcap-controls" class="d-flex align-items-center gap-1"
           data-table="<%= $table %>" data-id="<%= $id %>"
           data-filter="<%= $pcap_filter %>" data-start="<%= $pcap_start %>" data-end="<%= $pcap_end %>"
           title="Fetch the flow PCAP from a remote Virani instance">
        % if (@$pcap_remotes > 1) {
        <select id="pcap-remote" class="form-select form-select-sm" style="width:auto" title="Virani instance">
          % for my $r (@$pcap_remotes) {
          <option value="<%= $r %>" <%= (defined $pcap_default && $pcap_default eq $r) ? 'selected' : '' %>><%= $r %></option>
          % }
        </select>
        % } else {
        <input type="hidden" id="pcap-remote" value="<%= $pcap_remotes->[0] %>">
        % }
        <select id="pcap-set" class="form-select form-select-sm" style="width:auto" title="PCAP set">
          <option value="">(default set)</option>
        </select>
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn btn-outline-secondary" id="pcap-dl">Download PCAP</button>
          <button type="button" class="btn btn-outline-secondary dropdown-toggle dropdown-toggle-split"
                  data-bs-toggle="dropdown" aria-expanded="false"><span class="visually-hidden">Toggle</span></button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="#" id="pcap-local">Show local virani command</a></li>
          </ul>
        </div>
      </div>
      % }
      % if ($self->allani_enabled && @{ stash('log_links') || [] }) {
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                id="event-logs-toggle" data-bs-toggle="dropdown" aria-expanded="false"
                title="Browse Allani logs around this event">Logs</button>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="event-logs-toggle">
          % for my $l (@{ stash('log_links') }) {
          <li><a class="dropdown-item" href="<%= $l->{url} %>"><%= $l->{label} %></a></li>
          % }
        </ul>
      </div>
      % }
      % if ($self->escalation_enable) {
      <button type="button" class="btn btn-sm btn-danger" id="escalate-btn"
              data-bs-toggle="modal" data-bs-target="#escalate-modal">Escalate</button>
      % }
      <a href="/search?table=<%= $table %>&search=1" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
    </div>
  </div>
  % if ($pcap_available) {
  <div class="collapse border-bottom border-secondary" id="pcap-local-cmd">
    <div class="p-2">
      <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted small">Run on the box holding the PCAPs (adjust the set / output path as needed):</span>
        <div class="d-flex align-items-center gap-2">
          <button type="button" class="btn btn-sm btn-outline-secondary py-0" id="pcap-copy">Copy</button>
          <button type="button" class="btn-close btn-close-white" id="pcap-cmd-close" aria-label="Close"></button>
        </div>
      </div>
      <pre class="mb-0 mt-1 small font-monospace" id="pcap-cmd" style="white-space:pre-wrap"></pre>
    </div>
  </div>
  % }
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $key (sort grep { $_ ne 'raw' } keys %$event) {
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $key %></th>
          <td class="font-monospace">
            <%= ref $event->{$key} eq 'ARRAY' ? join(', ', @{$event->{$key}}) : $event->{$key} // '' %>
            % if (($key eq 'src_ip' || $key eq 'dest_ip') && $event->{$key}) {
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 ip-info-btn ms-1"
                    data-ip="<%= $event->{$key} %>" style="font-size:0.65rem;line-height:1.2">?</button>
            % if (my $cc = $self->ip_country($event->{$key})) {
            <span class="text-muted small" title="<%= $cc %>"><%= $self->country_flag($cc) %> <%= $cc %><% if (my $sub = $self->ip_subdivision($event->{$key})) { %>/<%= $sub %><% } %><% if (my $city = $self->ip_city($event->{$key})) { %> <%= $city %><% } %></span>
            % }
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'http' && ref $event->{raw}{http} eq 'HASH') {
  % my $h = $event->{raw}{http};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">HTTP Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(hostname http_method url protocol status http_content_type http_user_agent http_refer length)) {
          % next unless defined $h->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $h->{$field} %>
            % if ($field eq 'hostname') {
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $h->{$field} %>" style="font-size:0.65rem;line-height:1.2">?</button>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
  % if (defined $h->{http_request_body} || defined $h->{http_response_body}) {
  <div class="card-footer py-2 d-flex gap-2">
    % if (defined $h->{http_request_body}) {
    <button type="button" class="btn btn-sm btn-outline-secondary http-body-dl"
            data-body="<%= $h->{http_request_body} %>"
            data-filename="request-body-<%= $id %>"
            data-type="application/octet-stream">
      Download Request Body
    </button>
    % }
    % if (defined $h->{http_response_body}) {
    <button type="button" class="btn btn-sm btn-outline-secondary http-body-dl"
            data-body="<%= $h->{http_response_body} %>"
            data-filename="response-body-<%= $id %>"
            data-type="<%= $h->{http_content_type} || 'application/octet-stream' %>">
      Download Response Body
    </button>
    <a class="btn btn-sm btn-outline-secondary"
       href="/event/<%= $table %>/<%= $id %>/body/response/zip" download
       title="Password protected zip (password: infected)">
      Download Response Body (zip, pw: infected)
    </a>
    % }
  </div>
  % }
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'dns' && ref $event->{raw}{dns} eq 'HASH') {
  % my $d = $event->{raw}{dns};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">DNS Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(type id tx_id opcode rcode ttl rdata version flags rd rrname rrtype)) {
          % next unless defined $d->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= ref $d->{$field} eq 'ARRAY' ? join(', ', @{$d->{$field}}) : $d->{$field} %>
            % if ($field eq 'rrname' && !ref $d->{$field}) {
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $d->{$field} %>" style="font-size:0.65rem;line-height:1.2">?</button>
            % }
          </td>
        </tr>
        % }
        % if (ref $d->{queries} eq 'ARRAY' && @{$d->{queries}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">queries</th>
          <td class="font-monospace">
            % for my $q (@{$d->{queries}}) {
              <%= $q->{rrname} // '' %> <%= $q->{rrtype} // '' %>
              % if ($q->{rrname}) {
              <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $q->{rrname} %>" style="font-size:0.65rem;line-height:1.2">?</button>
              % }
              <br>
            % }
          </td>
        </tr>
        % }
        % if (ref $d->{answers} eq 'ARRAY' && @{$d->{answers}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">answers</th>
          <td class="font-monospace">
            % for my $ans (@{$d->{answers}}) {
              <%= $ans->{rrname} // '' %> <%= $ans->{rrtype} // '' %> <%= $ans->{rdata} // '' %> (ttl <%= $ans->{ttl} // '' %>)<br>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'tls' && ref $event->{raw}{tls} eq 'HASH') {
  % my $t = $event->{raw}{tls};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">TLS Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(sni version subject issuerdn serial fingerprint notbefore notafter)) {
          % next unless defined $t->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $t->{$field} %>
            % if ($field eq 'sni') {
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $t->{$field} %>" style="font-size:0.65rem;line-height:1.2">?</button>
            % }
          </td>
        </tr>
        % }
        % if (ref $t->{ja3} eq 'HASH') {
          % for my $field (qw(hash string)) {
            % next unless defined $t->{ja3}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ja3.<%= $field %></th>
          <td class="font-monospace"><%= $t->{ja3}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $t->{ja3s} eq 'HASH') {
          % for my $field (qw(hash string)) {
            % next unless defined $t->{ja3s}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ja3s.<%= $field %></th>
          <td class="font-monospace"><%= $t->{ja3s}{$field} %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'smtp' && ref $event->{raw}{smtp} eq 'HASH') {
  % my $s = $event->{raw}{smtp};
  % my $em = ref $event->{raw}{email} eq 'HASH' ? $event->{raw}{email} : {};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">SMTP Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(helo mail_from)) {
          % next unless defined $s->{$field};
          % (my $_smtp_domain = $s->{$field}) =~ s/^[^@]*@//;
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $s->{$field} %>
            % if ($field eq 'mail_from' && $_smtp_domain) {
            <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $_smtp_domain %>" style="font-size:0.65rem;line-height:1.2">?</button>
            % }
          </td>
        </tr>
        % }
        % if (ref $s->{rcpt_to} eq 'ARRAY' && @{$s->{rcpt_to}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">rcpt_to</th>
          <td class="font-monospace">
            % for my $addr (@{$s->{rcpt_to}}) {
              % (my $_rcpt_domain = $addr) =~ s/^[^@]*@//;
              <%= $addr %>
              % if ($_rcpt_domain) {
              <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1 domain-info-btn ms-1" data-domain="<%= $_rcpt_domain %>" style="font-size:0.65rem;line-height:1.2">?</button>
              % }
              <br>
            % }
          </td>
        </tr>
        % }
        % for my $field (qw(from to subject attachment)) {
          % next unless defined $em->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">email.<%= $field %></th>
          <td class="font-monospace"><%= ref $em->{$field} eq 'ARRAY' ? join(', ', @{$em->{$field}}) : $em->{$field} %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'ssh' && ref $event->{raw}{ssh} eq 'HASH') {
  % my $s = $event->{raw}{ssh};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">SSH Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % if (ref $s->{client} eq 'HASH') {
          % for my $field (qw(proto_version software_version)) {
            % next unless defined $s->{client}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">client.<%= $field %></th>
          <td class="font-monospace"><%= $s->{client}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $s->{server} eq 'HASH') {
          % for my $field (qw(proto_version software_version)) {
            % next unless defined $s->{server}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">server.<%= $field %></th>
          <td class="font-monospace"><%= $s->{server}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $s->{hassh} eq 'HASH') {
          % for my $field (qw(hash string)) {
            % next unless defined $s->{hassh}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">hassh.<%= $field %></th>
          <td class="font-monospace"><%= $s->{hassh}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $s->{hassh_server} eq 'HASH') {
          % for my $field (qw(hash string)) {
            % next unless defined $s->{hassh_server}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">hassh_server.<%= $field %></th>
          <td class="font-monospace"><%= $s->{hassh_server}{$field} %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'rdp' && ref $event->{raw}{rdp} eq 'HASH') {
  % my $r = $event->{raw}{rdp};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">RDP Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(tx_id event_type cookie)) {
          % next unless defined $r->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $r->{$field} %></td>
        </tr>
        % }
        % if (ref $r->{client} eq 'HASH') {
          % for my $field (qw(version build client_name desktop_width desktop_height color_depth keyboard_layout keyboard_type function_keys product_id)) {
            % next unless defined $r->{client}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">client.<%= $field %></th>
          <td class="font-monospace"><%= $r->{client}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $r->{x509_serials} eq 'ARRAY' && @{$r->{x509_serials}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">x509_serials</th>
          <td class="font-monospace"><%= join(', ', @{$r->{x509_serials}}) %></td>
        </tr>
        % }
        % if (ref $r->{channels} eq 'ARRAY' && @{$r->{channels}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">channels</th>
          <td class="font-monospace"><%= join(', ', @{$r->{channels}}) %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'ftp') {
  % my $f  = ref $event->{raw}{ftp}      eq 'HASH' ? $event->{raw}{ftp}      : {};
  % my $fd = ref $event->{raw}{ftp_data} eq 'HASH' ? $event->{raw}{ftp_data} : {};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">FTP Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(command command_data reply_code dynamic_port)) {
          % next unless defined $f->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $f->{$field} %></td>
        </tr>
        % }
        % for my $field (qw(reply_message completion_code)) {
          % next unless defined $f->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= ref $f->{$field} eq 'ARRAY' ? join(', ', @{$f->{$field}}) : $f->{$field} %></td>
        </tr>
        % }
        % for my $field (qw(filename command)) {
          % next unless defined $fd->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ftp_data.<%= $field %></th>
          <td class="font-monospace"><%= $fd->{$field} %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'dcerpc' && ref $event->{raw}{dcerpc} eq 'HASH') {
  % my $d = $event->{raw}{dcerpc};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">DCERPC Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(type pkt_type call_id rpc_version rpc_version_minor request response)) {
          % next unless defined $d->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $d->{$field} %></td>
        </tr>
        % }
        % if (ref $d->{req} eq 'HASH') {
          % for my $field (qw(opnum frag_cnt stub_data_size)) {
            % next unless defined $d->{req}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">req.<%= $field %></th>
          <td class="font-monospace"><%= $d->{req}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $d->{res} eq 'HASH') {
          % for my $field (qw(frag_cnt stub_data_size)) {
            % next unless defined $d->{res}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">res.<%= $field %></th>
          <td class="font-monospace"><%= $d->{res}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $d->{interfaces} eq 'ARRAY' && @{$d->{interfaces}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">interfaces</th>
          <td class="font-monospace">
            % for my $iface (@{$d->{interfaces}}) {
              <%= ref $iface eq 'HASH' ? join(' ', map { "$_=$iface->{$_}" } sort keys %$iface) : $iface %><br>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'smb' && ref $event->{raw}{smb} eq 'HASH') {
  % my $s = $event->{raw}{smb};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">SMB Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(id dialect command status status_code session_id tree_id filename fuid share named_pipe service host disposition access created accessed modified changed size)) {
          % next unless defined $s->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $s->{$field} %></td>
        </tr>
        % }
        % if (ref $s->{ntlmssp} eq 'HASH') {
          % for my $field (qw(domain user host)) {
            % next unless defined $s->{ntlmssp}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ntlmssp.<%= $field %></th>
          <td class="font-monospace"><%= $s->{ntlmssp}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $s->{kerberos} eq 'HASH') {
          % for my $field (qw(realm)) {
            % next unless defined $s->{kerberos}{$field};
        <tr>
