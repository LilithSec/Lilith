          % next unless defined $m->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $m->{$field} %></td>
        </tr>
        % }
        % if (ref $m->{queries} eq 'ARRAY' && @{$m->{queries}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">queries</th>
          <td class="font-monospace">
            % for my $q (@{$m->{queries}}) {
              <%= ref $q eq 'HASH' ? join(' ', map { "$_=$q->{$_}" } sort keys %$q) : $q %><br>
            % }
          </td>
        </tr>
        % }
        % if (ref $m->{answers} eq 'ARRAY' && @{$m->{answers}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">answers</th>
          <td class="font-monospace">
            % for my $a (@{$m->{answers}}) {
              <%= ref $a eq 'HASH' ? join(' ', map { "$_=$a->{$_}" } sort keys %$a) : $a %><br>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'llmnr' && ref $event->{raw}{llmnr} eq 'HASH') {
  % my $ll = $event->{raw}{llmnr};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">LLMNR Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(type id rrname rrtype rcode)) {
          % next unless defined $ll->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $ll->{$field} %></td>
        </tr>
        % }
        % if (ref $ll->{answers} eq 'ARRAY' && @{$ll->{answers}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">answers</th>
          <td class="font-monospace">
            % for my $a (@{$ll->{answers}}) {
              <%= ref $a eq 'HASH' ? join(' ', map { "$_=$a->{$_}" } sort keys %$a) : $a %><br>
            % }
          </td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'pop3' && ref $event->{raw}{pop3} eq 'HASH') {
  % my $p = $event->{raw}{pop3};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">POP3 Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % if (ref $p->{request} eq 'HASH') {
          % for my $field (qw(command)) {
            % next unless defined $p->{request}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">request.<%= $field %></th>
          <td class="font-monospace"><%= $p->{request}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $p->{response} eq 'HASH') {
          % for my $field (qw(status message)) {
            % next unless defined $p->{response}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">response.<%= $field %></th>
          <td class="font-monospace"><%= $p->{response}{$field} %></td>
        </tr>
          % }
        % }
        % for my $field (sort keys %$p) {
          % next if ref $p->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $p->{$field} %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'websocket' && ref $event->{raw}{websocket} eq 'HASH') {
  % my $w = $event->{raw}{websocket};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">WebSocket Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(opcode fin mask payload)) {
          % next unless defined $w->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $w->{$field} %></td>
        </tr>
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'ike' && ref $event->{raw}{ike} eq 'HASH') {
  % my $i = $event->{raw}{ike};
<div class="card border-secondary mb-3">
  <div class="card-header py-1 small text-muted">IKE Details</div>
  <div class="p-0">
    <table class="table table-dark table-sm table-bordered mb-0">
      <tbody>
        % for my $field (qw(init_spi resp_spi message_id maj_ver min_ver exchange_type role doi encrypted_payloads)) {
          % next unless defined $i->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= $i->{$field} %></td>
        </tr>
        % }
        % for my $field (qw(errors notify vendor_ids payload)) {
          % next unless defined $i->{$field} && ref $i->{$field} eq 'ARRAY' && @{$i->{$field}};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
          <td class="font-monospace"><%= join(', ', @{$i->{$field}}) %></td>
        </tr>
        % }
        % if (ref $i->{ikev1} eq 'HASH') {
          % my $v1 = $i->{ikev1};
          % for my $field (qw(sa_life_type sa_life_duration enc_alg hash_alg auth_method dh_group)) {
            % next unless defined $v1->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev1.<%= $field %></th>
          <td class="font-monospace"><%= $v1->{$field} %></td>
        </tr>
          % }
          % if (ref $v1->{transforms} eq 'ARRAY' && @{$v1->{transforms}}) {
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev1.transforms</th>
          <td class="font-monospace">
            % for my $t (@{$v1->{transforms}}) {
              <%= ref $t eq 'HASH' ? join(' ', map { "$_=$t->{$_}" } sort keys %$t) : $t %><br>
            % }
          </td>
        </tr>
          % }
        % }
        % if (ref $i->{ikev2} eq 'HASH') {
          % my $v2 = $i->{ikev2};
          % for my $field (qw(alg_enc alg_auth alg_prf alg_dh alg_esn)) {
            % next unless defined $v2->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev2.<%= $field %></th>
          <td class="font-monospace"><%= $v2->{$field} %></td>
        </tr>
          % }
          % for my $field (qw(notify child_sa)) {
            % next unless defined $v2->{$field} && ref $v2->{$field} eq 'ARRAY' && @{$v2->{$field}};
        <tr>
          <th style="width:180px" class="text-muted ps-3">ikev2.<%= $field %></th>
          <td class="font-monospace"><%= join(', ', @{$v2->{$field}}) %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if ($pretty_raw) {
<div class="card border-secondary">
  <div class="card-header py-2 d-flex align-items-center gap-2">
    <button class="btn btn-sm btn-outline-secondary" type="button"
            data-bs-toggle="collapse" data-bs-target="#raw-json-panel">
      Raw JSON
    </button>
    <button class="btn btn-sm btn-outline-secondary" type="button" id="download-json-btn">
      Download JSON
    </button>
    % if (ref $event->{raw} eq 'HASH' && defined $event->{raw}{payload}) {
    <button class="btn btn-sm btn-outline-secondary" type="button" id="download-payload-btn"
            data-payload="<%= $event->{raw}{payload} %>"
            data-filename="payload-<%= $table %>-<%= $id %>.bin">
      Download Payload
    </button>
    % }
    <span class="text-muted small">click to expand</span>
  </div>
  <div class="collapse" id="raw-json-panel">
    <div class="card-body p-2">
      <pre class="raw-json mb-0"><%= $pretty_raw %></pre>
    </div>
  </div>
</div>
% }

% }

<!-- IP Info Modal -->
<div class="modal fade" id="ipinfo-modal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content bg-dark text-light border-secondary">
      <div class="modal-header py-2 border-secondary">
        <h6 class="modal-title" id="ipinfo-modal-title">IP Info</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="ipinfo-loading" class="text-center text-muted py-3">Loading…</div>
        <div id="ipinfo-content" style="display:none">
          <div class="mb-2">
            <span class="text-muted small fw-semibold">Reverse DNS</span>
            <div id="ipinfo-rdns" class="font-monospace small mt-1"></div>
            <div id="ipinfo-ptr-name" class="text-muted small mt-1"></div>
            <div id="ipinfo-rdns-error" class="text-warning small mt-1" style="display:none"></div>
          </div>
          <div>
            <span class="text-muted small fw-semibold">WHOIS</span>
            <pre id="ipinfo-whois" class="small mt-1 mb-0" style="white-space:pre-wrap;max-height:400px;overflow-y:auto"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.http-body-dl').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var b64      = this.dataset.body;
      var filename = this.dataset.filename;
      var type     = this.dataset.type.split(';')[0].trim() || 'application/octet-stream';
      var binary   = atob(b64);
      var bytes    = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) { bytes[i] = binary.charCodeAt(i); }
      var blob = new Blob([bytes], { type: type });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href     = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    });
  });

  var payloadBtn = document.getElementById('download-payload-btn');
  if (payloadBtn) {
    payloadBtn.addEventListener('click', function() {
      var binary  = atob(this.dataset.payload);
      var bytes   = new Uint8Array(binary.length);
      for (var i = 0; i < binary.length; i++) { bytes[i] = binary.charCodeAt(i); }
      var blob = new Blob([bytes], { type: 'application/octet-stream' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href     = url;
      a.download = this.dataset.filename;
      a.click();
      URL.revokeObjectURL(url);
    });
  }

  var dlBtn = document.getElementById('download-json-btn');
  if (dlBtn) {
    dlBtn.addEventListener('click', function() {
      var json = document.querySelector('#raw-json-panel pre').textContent;
      var blob = new Blob([json], { type: 'application/json' });
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href     = url;
      a.download = 'event-<%= $table %>-<%= $id %>.json';
      a.click();
      URL.revokeObjectURL(url);
    });
  }

  var ipinfoModal = new bootstrap.Modal(document.getElementById('ipinfo-modal'));
  document.querySelectorAll('.ip-info-btn').forEach(function(el) {
    el.addEventListener('click', function() {
      var ip = this.dataset.ip;
      document.getElementById('ipinfo-modal-title').textContent = ip;
      document.getElementById('ipinfo-loading').style.display = '';
      document.getElementById('ipinfo-content').style.display = 'none';
      ipinfoModal.show();
      fetch('/api/ipinfo/' + encodeURIComponent(ip))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          document.getElementById('ipinfo-rdns').textContent     = data.rdns || '(none)';
          document.getElementById('ipinfo-ptr-name').textContent = data.ptr_name ? 'queried: ' + data.ptr_name : '';
          var errEl = document.getElementById('ipinfo-rdns-error');
          if (data.rdns_error) { errEl.textContent = data.rdns_error; errEl.style.display = ''; }
          else { errEl.style.display = 'none'; }
          document.getElementById('ipinfo-whois').textContent = data.whois || '(none)';
          document.getElementById('ipinfo-loading').style.display = 'none';
          document.getElementById('ipinfo-content').style.display = '';
        })
        .catch(function() {
          document.getElementById('ipinfo-rdns').textContent = 'Error fetching data';
          document.getElementById('ipinfo-whois').textContent = '';
          document.getElementById('ipinfo-loading').style.display = 'none';
          document.getElementById('ipinfo-content').style.display = '';
        });
    });
  });
});
</script>
