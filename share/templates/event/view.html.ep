          <td class="font-monospace"><%= $f->{$field} %></td>
        </tr>
        % }
        % for my $field (qw(reply_message completion_code)) {
          % next unless defined $f->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3"><%= $field %></th>
