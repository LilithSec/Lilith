        % if (ref $r->{server} eq 'HASH') {
          % for my $field (qw(protocol_major protocol_minor)) {
            % next unless defined $r->{server}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">server.<%= $field %></th>
          <td class="font-monospace"><%= $r->{server}{$field} %></td>
        </tr>
          % }
        % }
        % if (ref $r->{authentication} eq 'HASH') {
          % my $a = $r->{authentication};
          % for my $field (qw(security_type security_result)) {
            % next unless defined $a->{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">auth.<%= $field %></th>
          <td class="font-monospace"><%= $a->{$field} %></td>
        </tr>
          % }
          % if (ref $a->{vnc} eq 'HASH') {
            % for my $field (qw(challenge response)) {
              % next unless defined $a->{vnc}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">auth.vnc.<%= $field %></th>
          <td class="font-monospace"><%= $a->{vnc}{$field} %></td>
        </tr>
            % }
          % }
        % }
        % if (ref $r->{screen} eq 'HASH') {
          % for my $field (qw(width height name)) {
            % next unless defined $r->{screen}{$field};
        <tr>
          <th style="width:180px" class="text-muted ps-3">screen.<%= $field %></th>
          <td class="font-monospace"><%= $r->{screen}{$field} %></td>
        </tr>
          % }
        % }
      </tbody>
    </table>
  </div>
</div>
% }

% if (ref $event->{raw} eq 'HASH' && $event->{app_proto} && lc($event->{app_proto}) eq 'pgsql' && ref $event->{raw}{pgsql} eq 'HASH') {
