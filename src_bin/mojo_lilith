#!/usr/bin/env perl

=head1 NAME

mojo_lilith - Mojolicious web frontend for Lilith.

=head1 SYNOPSIS

mojo_lilith daemon

mojo_lilith daemon -l http://*:8080

LILITH_CONFIG=/etc/lilith.toml mojo_lilith daemon

=head1 DESCRIPTION

Starts the Lilith web frontend using Mojolicious. The config file is read
from C<LILITH_CONFIG> env var, defaulting to C</usr/local/etc/lilith.toml>.

Supports all standard Mojolicious server commands (daemon, prefork, etc).

=head1 SEE ALSO

L<Mojolicious::Commands>, L<Lilith::Web>

=cut

use strict;
use warnings;
use FindBin qw($Bin);
use lib "$Bin/../lib";
use Mojolicious::Commands;

Mojolicious::Commands->start_app('Lilith::Web');
