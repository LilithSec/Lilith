}

# Build the instance -> config hash for Lilith->run from the parsed TOML. EVE
# instances live under the [eves.*] table, e.g. [eves.suricata-eve]. Any leftover
# top-level table is warned about in case it is an old-style instance definition.
sub eve_instances {
	my ($toml) = @_;

	my %files;
	if ( ref( $toml->{eves} ) eq 'HASH' ) {
		foreach my $name ( keys( %{ $toml->{eves} } ) ) {
			next unless ref( $toml->{eves}{$name} ) eq 'HASH';
			$files{$name} = $toml->{eves}{$name};
		}
	}

	# Warn about stray top-level tables, which were instances prior to the move
	# under [eves.*].
	foreach my $key ( keys( %{$toml} ) ) {
		next if $key eq 'eves';
		next unless ref( $toml->{$key} ) eq 'HASH';
		warn( 'Top-level table [' . $key . '] is no longer used as an EVE instance; '
				. 'did you mean [eves.' . $key . ']?' . "\n" );
	}

	return %files;
} ## end sub eve_instances

# Init a Text::ANSITable with the standard Lilith styling and the passed
# columns.
sub esc_table {
	my (@columns) = @_;

	my $tb = Text::ANSITable->new;
	$tb->border_style( $ENV{Lilith_table_border} );
	$tb->color_theme( $ENV{Lilith_table_color} );

	my $header_int = 0;
	foreach my $header (@columns) {
		$tb->set_column_style( $header_int, pad => ( ( $header_int % 2 ) != 0 ? 1 : 0 ) );
		$header_int++;
	}
	$tb->columns( \@columns );

	return $tb;
} ## end sub esc_table

# Parse repeated --set key=value items into a config hash ref, dieing on
# anything malformed.
sub esc_parse_set {
	my (@set) = @_;

	my %config;
	foreach my $item (@set) {
		if ( $item =~ /^([A-Za-z0-9_]+)=(.*)$/s ) {
			$config{$1} = $2;
		} else {
			die( '"' . $item . '" for --set is not in the form key=value' );
		}
	}

	return \%config;
} ## end sub esc_parse_set

# Look up a escalation target, by --tid when given and by --name otherwise.
sub esc_lookup_target {
	my ( $lilith, $tid, $name ) = @_;

	if ( defined($tid) && $tid ne '' ) {
		if ( $tid !~ /^[0-9]+$/ ) {
			die( '"' . $tid . '" for --tid is not numeric' );
		}
		return $lilith->escalation_target_get($tid);
	}

	if ( defined($name) && $name ne '' ) {
		my $targets = $lilith->escalation_targets;
		my ($match) = grep { $_->{name} eq $name } @{$targets};
		if ( !$match ) {
			die( 'no escalation target named "'
					. $name . '"'
					. ( @{$targets} ? '; known: ' . join( ', ', map { $_->{name} } @{$targets} ) : '' ) );
		}
		return $match;
	} ## end if ( defined($name) && $name ne '' )

	die('either --tid or --name is required for picking the escalation target');
} ## end sub esc_lookup_target

# Resolve the comma separated --to list into a array ref of escalation
# target IDs. All numeric items are taken as IDs; anything else is matched
# against target names.
sub esc_resolve_targets {
	my ( $lilith, $to ) = @_;

	my @tokens = grep { $_ ne '' } split( /\s*,\s*/, defined($to) ? $to : '' );
	if ( !@tokens ) {
		die('--to is required and must be a comma separated list of escalation target IDs or names');
	}

	my $targets;
	my @ids;
	foreach my $token (@tokens) {
		if ( $token =~ /^[0-9]+$/ ) {
			push( @ids, $token );
			next;
		}

		if ( !defined($targets) ) {
			$targets = $lilith->escalation_targets;
		}
		my ($match) = grep { $_->{name} eq $token } @{$targets};
		if ( !$match ) {
			die( 'no escalation target named "'
					. $token . '"'
					. ( @{$targets} ? '; known: ' . join( ', ', map { $_->{name} } @{$targets} ) : '' ) );
		}
		push( @ids, $match->{id} );
	} ## end foreach my $token (@tokens)

	return \@ids;
} ## end sub esc_resolve_targets

# reads the --rule value, which is either a JSON string or, when it begins
# with '@', the path to a file holding the JSON. Returns the decoded hash ref.
sub ae_read_rule {
	my ($rule) = @_;

	if ( !defined($rule) || $rule eq '' ) {
		die('--rule is required and must be a JSON object (or @file)');
	}

	my $json = $rule;
	if ( $rule =~ /^\@(.+)$/ ) {
		my $file = $1;
		$json = read_file($file) or die( 'failed to read rule file "' . $file . '"' );
	}

	my $decoded;
	eval { $decoded = decode_json($json); };
	if ( $@ || ref($decoded) ne 'HASH' ) {
		die( 'could not parse --rule as a JSON object: ' . ( $@ ? $@ : 'not a object' ) );
	}

	return $decoded;
} ## end sub ae_read_rule

