#
# creates a escalation target
#

if ( $action eq 'esc_target_create' ) {
	if ( !defined($esc_name) || $esc_name eq '' ) {
		die('--name is required for creating a escalation target');
	}
	if ( !defined($esc_type) || $esc_type eq '' ) {
		die('--type is required for creating a escalation target');
	}

	my $config = esc_parse_set(@esc_set);

	# empty values make no sense on create; drop them so type defaults apply
	foreach my $key ( keys( %{$config} ) ) {
		if ( $config->{$key} eq '' ) {
			delete( $config->{$key} );
		}
	}

	my $new_id = $lilith->escalation_target_create(
		name        => $esc_name,
		type        => $esc_type,
		config      => $config,
		description => $esc_desc,
		enabled     => ( $esc_disable ? 0 : 1 ),
	);

	print 'created escalation target ' . $new_id . "\n";

	exit 0;
} ## end if ( $action eq 'esc_target_create' )

#
# updates a escalation target
#

if ( $action eq 'esc_target_update' ) {
	if ( $esc_enable && $esc_disable ) {
		die('--enable and --disable are mutually exclusive');
	}

	my $existing = esc_lookup_target( $lilith, $esc_tid, $esc_name );

	my %update = ( id => $existing->{id} );

	# --set items are merged over the current config; a empty value removes
	# that key so the type default applies again
	if (@esc_set) {
		my $set    = esc_parse_set(@esc_set);
		my $config = { %{ $existing->{config} } };
		foreach my $key ( keys( %{$set} ) ) {
			if ( $set->{$key} eq '' ) {
				delete( $config->{$key} );
			} else {
				$config->{$key} = $set->{$key};
			}
		}
		$update{config} = $config;
	} ## end if (@esc_set)

	# when picked via --tid, --name is the new name
	if ( defined($esc_tid) && $esc_tid ne '' && defined($esc_name) && $esc_name ne '' ) {
		$update{name} = $esc_name;
	}
	if ( defined($esc_desc) ) {
		$update{description} = $esc_desc;
	}
	if ($esc_enable) {
		$update{enabled} = 1;
	}
	if ($esc_disable) {
		$update{enabled} = 0;
	}

	$lilith->escalation_target_update(%update);

	print 'updated escalation target ' . $existing->{id} . "\n";

	exit 0;
} ## end if ( $action eq 'esc_target_update' )

#
# deletes a escalation target
#

if ( $action eq 'esc_target_delete' ) {
	my $existing = esc_lookup_target( $lilith, $esc_tid, $esc_name );

	$lilith->escalation_target_delete( $existing->{id} );

	print 'deleted escalation target ' . $existing->{id} . ', "' . $existing->{name} . '"' . "\n";

	exit 0;
}

#
# sends a synthetic test event to a escalation target
#

if ( $action eq 'esc_target_test' ) {
	my $existing = esc_lookup_target( $lilith, $esc_tid, $esc_name );

	my $payload = $lilith->escalation_test( id => $existing->{id} );

	my $json = JSON->new;
	if ($pretty) {
		$json->canonical(1);
		$json->pretty(1);
