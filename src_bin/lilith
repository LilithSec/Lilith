#
# creates a auto escalation rule
#
if ( $action eq 'ae_create' ) {
	if ( !defined($esc_name) || $esc_name eq '' ) {
		die('--name is required for creating a auto escalation rule');
	}

	my $rule = ae_read_rule($ae_rule);

	my @tables = grep { $_ ne '' } split( /\s*,\s*/, defined($ae_tables) ? $ae_tables : '' );

	my $new_id = $lilith->auto_escalation_create(
		name          => $esc_name,
		rule          => $rule,
		tables        => ( @tables ? \@tables : undef ),
		priority      => $ae_priority,
		stop_on_match => ( $ae_stop ? 1 : 0 ),
		description   => $esc_desc,
		enabled       => ( $esc_disable ? 0 : 1 ),
	);

	print 'created auto escalation ' . $new_id . "\n";

	exit 0;
} ## end if ( $action eq 'ae_create' )

#
# updates a auto escalation rule
#
if ( $action eq 'ae_update' ) {
	if ( !defined( $id[0] ) ) {
		die('--id is required for updating a auto escalation rule');
	}

	my %update = ( id => $id[0] );

	if ( defined($esc_name) && $esc_name ne '' ) {
		$update{name} = $esc_name;
	}
	if ( defined($ae_rule) && $ae_rule ne '' ) {
		$update{rule} = ae_read_rule($ae_rule);
	}
	if ( defined($ae_tables) ) {
		my @tables = grep { $_ ne '' } split( /\s*,\s*/, $ae_tables );
		$update{tables} = \@tables;
	}
	if ( defined($ae_priority) ) {
		$update{priority} = $ae_priority;
	}
	if ($ae_stop) {
		$update{stop_on_match} = 1;
	}
	if ( defined($esc_desc) ) {
		$update{description} = $esc_desc;
	}
	if ($esc_enable) {
		$update{enabled} = 1;
	}
	if ($esc_disable) {
		$update{enabled} = 0;
	}

	$lilith->auto_escalation_update(%update);

	print 'updated auto escalation ' . $id[0] . "\n";

	exit 0;
} ## end if ( $action eq 'ae_update' )

#
# deletes a auto escalation rule
#
if ( $action eq 'ae_delete' ) {
	if ( !defined( $id[0] ) ) {
		die('--id is required for deleting a auto escalation rule');
	}

	$lilith->auto_escalation_delete( $id[0] );

	print 'deleted auto escalation ' . $id[0] . "\n";

	exit 0;
} ## end if ( $action eq 'ae_delete' )

