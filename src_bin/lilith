		print "\n";
	}

	exit 0;
} ## end if ( $action eq 'esc_target_test' )

#
# escalates a event
#

if ( $action eq 'esc' ) {
	if ( !defined( $id[0] ) ) {
		die('--id is required for escalating a event');
	}

	my $target_ids = esc_resolve_targets( $lilith, $esc_to );

	if ( !defined($esc_by) || $esc_by eq '' ) {
		$esc_by = getlogin || getpwuid($<) || 'unknown';
	}

	my $results = $lilith->escalate(
		table        => $table,
		id           => $id[0],
		target_ids   => $target_ids,
		note         => $esc_note,
		requested_by => $esc_by,
	);

	my $failed = scalar( grep { $_->{status} ne 'sent' } @{$results} );

	if ( $search_output eq 'json' ) {
		my $json = JSON->new;
		if ($pretty) {
			$json->canonical(1);
			$json->pretty(1);
		}
		print $json->encode($results);
		if ( !$pretty ) {
			print "\n";
		}
		exit( $failed ? 1 : 0 );
	} ## end if ( $search_output eq 'json' )

	my $tb = esc_table( 'Target', 'Status', 'Escalation ID', 'Error' );
	my @td;
	foreach my $result ( @{$results} ) {
		push(
			@td,
			[
				defined( $result->{target_name} ) ? $result->{target_name} : ( 'id ' . $result->{target_id} ),
				$result->{status},
				defined( $result->{escalation_id} ) ? $result->{escalation_id} : '',
				defined( $result->{error} )         ? $result->{error}         : '',
			]
		);
	} ## end foreach my $result ( @{$results} )
	$tb->add_rows( \@td );
	print $tb->draw;

	exit( $failed ? 1 : 0 );
} ## end if ( $action eq 'esc' )

#
# prints the escalations recorded for a event
#

if ( $action eq 'esc_history' ) {
	if ( !defined( $id[0] ) ) {
		die('--id is required for fetching the escalations for a event');
	}

	my $escalations = $lilith->escalations_for(
		table => $table,
		id    => $id[0],
	);

	if ( $search_output eq 'json' ) {
		# mirror the event action; the raw is decoded unless --raw is given
		if ( !$decode_raw ) {
			foreach my $escalation ( @{$escalations} ) {
				if ( defined( $escalation->{raw} ) && !ref( $escalation->{raw} ) ) {
					my $decoded;
					eval { $decoded = decode_json( $escalation->{raw} ) };
					if ( !$@ && ref($decoded) ) {
						$escalation->{raw} = $decoded;
					}
				}
			}
		} ## end if ( !$decode_raw )

		my $json = JSON->new;
		if ($pretty) {
			$json->canonical(1);
			$json->pretty(1);
		}
		print $json->encode($escalations);
		if ( !$pretty ) {
			print "\n";
		}
		exit 0;
	} ## end if ( $search_output eq 'json' )

	my $tb = esc_table( 'ID', 'Time', 'Target', 'Status', 'By', 'Note', 'Error' );
	my @td;
	foreach my $escalation ( @{$escalations} ) {
		push(
			@td,
			[
				$escalation->{id},
				defined( $escalation->{timestamp} )    ? $escalation->{timestamp}    : '',
				defined( $escalation->{target_name} )  ? $escalation->{target_name}  : '',
				$escalation->{status},
				defined( $escalation->{requested_by} ) ? $escalation->{requested_by} : '',
				defined( $escalation->{note} )         ? $escalation->{note}         : '',
				defined( $escalation->{error} )        ? $escalation->{error}        : '',
			]
		);
	} ## end foreach my $escalation ( @{$escalations} )
	$tb->add_rows( \@td );
	print $tb->draw;

	exit 0;
} ## end if ( $action eq 'esc_history' )

#
# evaluates the auto escalation rules against recent alerts
#
if ( $action eq 'auto_escalate' ) {
	if ( !defined($go_back_minutes) ) {
		$go_back_minutes = 5;
	}

	# --tables scopes which alert tables are scanned; all three by default
	my @tables = grep { $_ ne '' } split( /\s*,\s*/, defined($ae_tables) ? $ae_tables : '' );
	if ( !@tables ) {
		@tables = ( 'suricata', 'sagan', 'cape' );
	}

	if ( !defined($esc_by) || $esc_by eq '' ) {
		$esc_by = 'auto';
	}

	my @summaries;
	foreach my $ae_table (@tables) {
		my $result = $lilith->auto_escalate(
			table           => $ae_table,
			go_back_minutes => $go_back_minutes,
			dry_run         => ( $ae_dry_run ? 1 : 0 ),
			requested_by    => $esc_by,
		);
		push( @summaries, @{$result} );
	} ## end foreach my $ae_table (@tables)

	if ( $search_output eq 'json' ) {
		my $json = JSON->new;
		if ($pretty) {
			$json->canonical(1);
			$json->pretty(1);
		}
		print $json->encode( \@summaries );
		if ( !$pretty ) {
			print "\n";
		}
		exit 0;
	} ## end if ( $search_output eq 'json' )

	my $tb = esc_table( 'Table', 'Scanned', 'Rules', 'Matched', 'Alert', 'Rule', 'Targets', 'Status' );
	my @td;
	foreach my $summary (@summaries) {
		if ( !@{ $summary->{escalations} } ) {
			push( @td,
				[ $summary->{table}, $summary->{scanned}, $summary->{rules}, $summary->{matched}, '', '', '', '' ] );
			next;
		}
		foreach my $entry ( @{ $summary->{escalations} } ) {
			my @targets = @{ $entry->{target_ids} };
			push( @targets, map { $_ . '?' } @{ $entry->{unknown_targets} } );
			push(
				@td,
				[
					$summary->{table}, $summary->{scanned}, $summary->{rules}, $summary->{matched},
					$entry->{alert_id}, $entry->{rule_name}, join( ',', @targets ), $entry->{status},
				]
			);
		} ## end foreach my $entry ( @{ $summary...})
	} ## end foreach my $summary (@summaries)
	$tb->add_rows( \@td );
	print $tb->draw;

	exit 0;
} ## end if ( $action eq 'auto_escalate' )

#
# lists the auto escalation rules
